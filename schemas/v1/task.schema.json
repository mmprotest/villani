{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/task.schema.json",
  "title": "Villani Task Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "run_id",
    "created_at",
    "repository_path",
    "instruction",
    "success_criteria",
    "constraints",
    "requires_file_changes",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "villani.task.v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "repository_path": { "type": "string", "minLength": 1 },
    "instruction": { "type": "string", "minLength": 1 },
    "success_criteria": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_file_changes": { "type": "boolean" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
