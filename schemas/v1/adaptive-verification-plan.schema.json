{
  "$defs": {
    "VerificationPlanNode": {
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "pattern": "^node_[a-z0-9_]+$",
          "title": "Node Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "repository_validation",
            "focused_probe",
            "changed_test_execution",
            "static_checks",
            "diff_integrity",
            "generated_artifact_exclusion",
            "requirement_mapping",
            "semantic_verifier",
            "independent_second_verifier",
            "manual_review"
          ],
          "title": "Kind",
          "type": "string"
        },
        "disposition": {
          "enum": [
            "required",
            "conditional",
            "omitted"
          ],
          "title": "Disposition",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "repository_commands": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Repository Commands",
          "type": "array"
        },
        "evidence_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Requirements",
          "type": "array"
        },
        "estimated_model_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Model Calls"
        }
      },
      "required": [
        "node_id",
        "kind",
        "disposition",
        "reason"
      ],
      "title": "VerificationPlanNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "villani.adaptive_verification_plan.v1",
      "default": "villani.adaptive_verification_plan.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "plan_id": {
      "pattern": "^avp_[0-9a-f]{64}$",
      "title": "Plan Id",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "attempt_id": {
      "minLength": 1,
      "title": "Attempt Id",
      "type": "string"
    },
    "policy_version": {
      "const": "adaptive_verification_v1",
      "default": "adaptive_verification_v1",
      "title": "Policy Version",
      "type": "string"
    },
    "policy_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Policy Digest",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "risk_tier": {
      "enum": [
        "standard",
        "elevated",
        "critical"
      ],
      "title": "Risk Tier",
      "type": "string"
    },
    "risk_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Risk Reasons",
      "type": "array"
    },
    "task_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Task Digest",
      "type": "string"
    },
    "criteria_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Criteria Digest",
      "type": "string"
    },
    "candidate_diff_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Candidate Diff Digest",
      "type": "string"
    },
    "changed_files": {
      "items": {
        "type": "string"
      },
      "title": "Changed Files",
      "type": "array"
    },
    "requirement_ids": {
      "items": {
        "type": "string"
      },
      "title": "Requirement Ids",
      "type": "array"
    },
    "qualification_state": {
      "enum": [
        "qualified",
        "provisional",
        "experimental",
        "unsupported",
        "unknown"
      ],
      "title": "Qualification State",
      "type": "string"
    },
    "historical_failure_modes": {
      "items": {
        "type": "string"
      },
      "title": "Historical Failure Modes",
      "type": "array"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/VerificationPlanNode"
      },
      "minItems": 1,
      "title": "Nodes",
      "type": "array"
    },
    "independent_verifier_required": {
      "title": "Independent Verifier Required",
      "type": "boolean"
    },
    "manual_review_if_unresolved": {
      "title": "Manual Review If Unresolved",
      "type": "boolean"
    },
    "semantic_context_allowlist": {
      "items": {
        "type": "string"
      },
      "title": "Semantic Context Allowlist",
      "type": "array"
    },
    "semantic_context_excluded": {
      "items": {
        "type": "string"
      },
      "title": "Semantic Context Excluded",
      "type": "array"
    },
    "deterministic_input_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Deterministic Input Digest",
      "type": "string"
    }
  },
  "required": [
    "plan_id",
    "run_id",
    "attempt_id",
    "policy_digest",
    "created_at",
    "risk_tier",
    "risk_reasons",
    "task_digest",
    "criteria_digest",
    "candidate_diff_digest",
    "changed_files",
    "requirement_ids",
    "qualification_state",
    "historical_failure_modes",
    "nodes",
    "independent_verifier_required",
    "manual_review_if_unresolved",
    "semantic_context_allowlist",
    "semantic_context_excluded",
    "deterministic_input_digest"
  ],
  "title": "AdaptiveVerificationPlan",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/adaptive-verification-plan.schema.json"
}
