{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/cli-classifier-result.schema.json",
  "title": "Villani CLI classifier result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "difficulty",
    "risk",
    "category",
    "required_capabilities",
    "uncertainty",
    "confidence",
    "estimated_attempts_needed",
    "needs_tests",
    "likely_files",
    "reasoning_summary"
  ],
  "properties": {
    "difficulty": {"enum": ["easy", "medium", "hard"]},
    "risk": {"enum": ["low", "medium", "high"]},
    "category": {"type": "string", "minLength": 1, "maxLength": 80},
    "required_capabilities": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "uncertainty": {"enum": ["low", "medium", "high"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "estimated_attempts_needed": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "needs_tests": {"type": "boolean"},
    "likely_files": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "reasoning_summary": {"type": "string", "minLength": 1, "maxLength": 800}
  }
}
