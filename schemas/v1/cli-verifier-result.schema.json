{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/cli-verifier-result.schema.json",
  "title": "Villani CLI Verifier Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "reason",
    "requirements_proved",
    "requirements_not_proved",
    "blocking_issues"
  ],
  "properties": {
    "decision": {
      "type": "integer",
      "enum": [0, 1]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "requirements_proved": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requirements_not_proved": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "summary", "evidence_reference"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$",
            "maxLength": 128
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "evidence_reference": {
            "type": "string",
            "pattern": "^input/.+$",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    }
  }
}
