    "cheap-only": {"villani_home": "/absolute/path/to/cheap-only-home", "configuration": {"policy": "cheap-only"}},
    "cheap-first-escalation": {"villani_home": "/absolute/path/to/cheap-first-home", "configuration": {"policy": "cheap-first-escalation"}},
    "strong-first": {"villani_home": "/absolute/path/to/strong-first-home", "configuration": {"policy": "strong-first"}},
