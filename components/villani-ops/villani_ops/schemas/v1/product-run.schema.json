{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/product-run.schema.json",
  "title": "Villani Product Run v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_identity", "task_summary", "current_stage",
    "stage_sentence", "stage_transitions", "final_verdict", "verdict_reason",
    "change_summary", "changed_files", "checks_summary", "requirement_summary",
    "cost", "duration", "agent_system", "escalation_summary",
    "available_actions", "evidence_links", "recovery_action",
    "technical_detail_references", "target_repository", "last_event_sequence",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "villani.product_run.v1" },
    "run_identity": { "$ref": "#/$defs/run_identity" },
    "task_summary": { "$ref": "#/$defs/task_summary" },
    "current_stage": { "$ref": "#/$defs/stage" },
    "stage_sentence": { "type": "string", "minLength": 1 },
    "stage_transitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/stage_transition" } },
    "final_verdict": { "anyOf": [{ "enum": ["Ready to apply", "Needs review", "Could not prove", "Cancelled"] }, { "type": "null" }] },
    "verdict_reason": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
    "change_summary": { "type": "string", "minLength": 1 },
    "changed_files": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "checks_summary": { "$ref": "#/$defs/checks" },
    "requirement_summary": { "$ref": "#/$defs/requirements" },
    "cost": { "$ref": "#/$defs/cost" },
    "duration": { "$ref": "#/$defs/duration" },
    "agent_system": { "$ref": "#/$defs/agent_system" },
    "role_executions": { "type": "array", "items": { "$ref": "#/$defs/role_execution" } },
    "escalation_summary": { "$ref": "#/$defs/escalation" },
    "available_actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
    "evidence_links": { "type": "array", "items": { "$ref": "#/$defs/evidence_link" } },
    "recovery_action": { "anyOf": [{ "$ref": "#/$defs/recovery_action" }, { "type": "null" }] },
    "technical_detail_references": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "target_repository": { "$ref": "#/$defs/target_repository" },
    "proof_package": { "anyOf": [{ "$ref": "#/$defs/proof_package" }, { "type": "null" }] },
    "last_event_sequence": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "stage": { "enum": ["Understanding", "Working", "Checking", "Ready"] },
    "accounting_status": { "enum": ["complete", "partial", "unknown", "not_applicable"] },
    "run_identity": { "type": "object", "additionalProperties": false, "required": ["run_id", "trace_id"], "properties": { "run_id": { "type": "string", "minLength": 1 }, "trace_id": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] } } },
    "task_summary": { "type": "object", "additionalProperties": false, "required": ["task", "success_criteria", "repository"], "properties": { "task": { "type": "string", "minLength": 1 }, "success_criteria": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }, "repository": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] } } },
    "stage_transition": { "type": "object", "additionalProperties": false, "required": ["sequence", "timestamp", "stage", "sentence"], "properties": { "sequence": { "type": "integer", "minimum": 1 }, "timestamp": { "type": "string", "minLength": 1 }, "stage": { "$ref": "#/$defs/stage" }, "sentence": { "type": "string", "minLength": 1 } } },
    "checks": { "type": "object", "additionalProperties": false, "required": ["passed", "failed", "not_run", "unavailable", "accounting_status"], "properties": { "passed": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "failed": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "not_run": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "unavailable": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "accounting_status": { "enum": ["complete", "unknown"] } } },
    "requirements": { "type": "object", "additionalProperties": false, "required": ["proved", "not_proved", "accounting_status"], "properties": { "proved": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "not_proved": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "accounting_status": { "enum": ["complete", "unknown"] } } },
    "cost": { "type": "object", "additionalProperties": false, "required": ["value", "currency", "accounting_status"], "properties": { "value": { "anyOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] }, "currency": { "anyOf": [{ "type": "string", "pattern": "^[A-Za-z]{3}$" }, { "type": "null" }] }, "accounting_status": { "$ref": "#/$defs/accounting_status" } } },
    "duration": { "type": "object", "additionalProperties": false, "required": ["value_ms", "accounting_status"], "properties": { "value_ms": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] }, "accounting_status": { "$ref": "#/$defs/accounting_status" } } },
    "agent_system": { "type": "object", "additionalProperties": false, "required": ["name", "backend", "model"], "properties": { "name": { "type": "string" }, "backend": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }, "model": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] } } },
    "role_execution": { "type": "object", "additionalProperties": false, "required": ["role", "label", "agent_system_id", "system_name", "driver", "model", "invocation_count", "status", "evidence_artifact"], "properties": { "role": { "enum": ["classification", "coding", "verification", "selection"] }, "label": { "enum": ["Understand task", "Write code", "Verify result", "Choose candidate"] }, "agent_system_id": { "type": "string", "minLength": 1 }, "system_name": { "type": "string", "minLength": 1 }, "driver": { "type": "string", "minLength": 1 }, "model": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }, "invocation_count": { "type": "integer", "minimum": 0 }, "status": { "enum": ["recorded", "succeeded", "infrastructure_failure", "not_invoked"] }, "evidence_artifact": { "type": "string", "minLength": 1 }, "infrastructure_failure": { "anyOf": [{ "$ref": "#/$defs/role_infrastructure_failure" }, { "type": "null" }] } } },
    "role_infrastructure_failure": { "type": "object", "additionalProperties": false, "required": ["stage", "role", "agent_system_id", "safe_error_summary", "target_repository_modified", "partial_patch_preserved", "automatic_fallback_performed", "exact_repair_action", "evidence_path"], "properties": { "stage": { "enum": ["classification", "coding", "verification", "selection"] }, "role": { "enum": ["classification", "coding", "verification", "selection"] }, "agent_system_id": { "type": "string", "minLength": 1 }, "safe_error_summary": { "type": "string", "minLength": 1 }, "target_repository_modified": { "type": "boolean" }, "partial_patch_preserved": { "type": "boolean" }, "automatic_fallback_performed": { "type": "boolean" }, "exact_repair_action": { "type": "string", "minLength": 1 }, "evidence_path": { "type": "string", "minLength": 1 } } },
    "escalation": { "type": "object", "additionalProperties": false, "required": ["attempts", "retries", "escalations", "summary"], "properties": { "attempts": { "type": "integer", "minimum": 0 }, "retries": { "type": "integer", "minimum": 0 }, "escalations": { "type": "integer", "minimum": 0 }, "summary": { "type": "string", "minLength": 1 } } },
    "action": { "type": "object", "additionalProperties": false, "required": ["id", "label", "method", "href"], "properties": { "id": { "enum": ["apply_change", "create_branch", "open_pull_request", "cancel", "retry", "review_evidence"] }, "label": { "type": "string", "minLength": 1 }, "method": { "enum": ["GET", "POST"] }, "href": { "type": "string", "minLength": 1 } } },
    "evidence_link": { "type": "object", "additionalProperties": false, "required": ["label", "href", "artifact"], "properties": { "label": { "type": "string", "minLength": 1 }, "href": { "type": "string", "minLength": 1 }, "artifact": { "type": "string", "minLength": 1 } } },
    "recovery_action": { "type": "object", "additionalProperties": false, "required": ["label", "instruction", "href"], "properties": { "label": { "type": "string", "minLength": 1 }, "instruction": { "type": "string", "minLength": 1 }, "href": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] } } },
    "target_repository": { "type": "object", "additionalProperties": false, "required": ["modified", "accounting_status", "statement"], "properties": { "modified": { "anyOf": [{ "type": "boolean" }, { "type": "null" }] }, "accounting_status": { "enum": ["known", "unknown"] }, "statement": { "type": "string", "minLength": 1 } } },
    "proof_package": { "type": "object", "additionalProperties": false, "required": ["status", "risk_tier", "why_villani_trusts_it", "unresolved_decision", "artifact"], "properties": { "status": { "enum": ["ready_to_apply", "needs_review"] }, "risk_tier": { "enum": ["standard", "elevated", "critical"] }, "why_villani_trusts_it": { "type": "string", "minLength": 1 }, "unresolved_decision": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }, "artifact": { "type": "string", "minLength": 1 } } }
  }
}
