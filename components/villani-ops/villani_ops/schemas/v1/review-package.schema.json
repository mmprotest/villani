{
  "$defs": {
    "DurationAccounting": {
      "additionalProperties": false,
      "properties": {
        "duration_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Ms"
        },
        "accounting_status": {
          "enum": [
            "complete",
            "partial",
            "unknown",
            "not_applicable"
          ],
          "title": "Accounting Status",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "accounting_status",
        "source"
      ],
      "title": "DurationAccounting",
      "type": "object"
    },
    "MoneyAccounting": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount"
        },
        "currency": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z]{3}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency"
        },
        "accounting_status": {
          "enum": [
            "complete",
            "partial",
            "unknown",
            "not_applicable"
          ],
          "title": "Accounting Status",
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "accounting_status",
        "source"
      ],
      "title": "MoneyAccounting",
      "type": "object"
    },
    "ReviewCheck": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "not_run",
            "unavailable",
            "infrastructure_error"
          ],
          "title": "Status",
          "type": "string"
        },
        "evidence_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Path"
        }
      },
      "required": [
        "label",
        "status"
      ],
      "title": "ReviewCheck",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "villani.review_package.v1",
      "default": "villani.review_package.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "package_id": {
      "pattern": "^rvp_[0-9a-f]{64}$",
      "title": "Package Id",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "attempt_id": {
      "minLength": 1,
      "title": "Attempt Id",
      "type": "string"
    },
    "decision_id": {
      "pattern": "^avd_[0-9a-f]{64}$",
      "title": "Decision Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "status": {
      "enum": [
        "ready_to_apply",
        "needs_review"
      ],
      "title": "Status",
      "type": "string"
    },
    "task": {
      "minLength": 1,
      "title": "Task",
      "type": "string"
    },
    "change_summary": {
      "minLength": 1,
      "title": "Change Summary",
      "type": "string"
    },
    "changed_files": {
      "items": {
        "type": "string"
      },
      "title": "Changed Files",
      "type": "array"
    },
    "requirements_proved": {
      "items": {
        "type": "string"
      },
      "title": "Requirements Proved",
      "type": "array"
    },
    "requirements_not_proved": {
      "items": {
        "type": "string"
      },
      "title": "Requirements Not Proved",
      "type": "array"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/ReviewCheck"
      },
      "title": "Checks",
      "type": "array"
    },
    "risk_tier": {
      "enum": [
        "standard",
        "elevated",
        "critical"
      ],
      "title": "Risk Tier",
      "type": "string"
    },
    "risk_flags": {
      "items": {
        "type": "string"
      },
      "title": "Risk Flags",
      "type": "array"
    },
    "known_cost": {
      "$ref": "#/$defs/MoneyAccounting"
    },
    "known_duration": {
      "$ref": "#/$defs/DurationAccounting"
    },
    "why_villani_trusts_it": {
      "minLength": 1,
      "title": "Why Villani Trusts It",
      "type": "string"
    },
    "unresolved_decision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Unresolved Decision"
    },
    "full_evidence_href": {
      "minLength": 1,
      "title": "Full Evidence Href",
      "type": "string"
    }
  },
  "required": [
    "package_id",
    "run_id",
    "attempt_id",
    "decision_id",
    "created_at",
    "status",
    "task",
    "change_summary",
    "changed_files",
    "requirements_proved",
    "requirements_not_proved",
    "checks",
    "risk_tier",
    "risk_flags",
    "known_cost",
    "known_duration",
    "why_villani_trusts_it",
    "full_evidence_href"
  ],
  "title": "CompactReviewPackage",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/review-package.schema.json"
}
