{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/run-state.schema.json",
  "title": "Villani Run State Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "trace_id",
    "state",
    "previous_state",
    "terminal",
    "updated_at",
    "last_event_id",
    "last_sequence",
    "active_attempt_id",
    "attempt_count",
    "accepted_candidate_ids",
    "failure",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "villani.run_state.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "state": { "$ref": "#/$defs/controller_state" },
    "previous_state": {
      "anyOf": [
        { "$ref": "#/$defs/controller_state" },
        { "type": "null" }
      ]
    },
    "terminal": { "type": "boolean" },
    "updated_at": { "$ref": "#/$defs/utc_timestamp" },
    "last_event_id": { "type": "string", "minLength": 1 },
    "last_sequence": { "type": "integer", "minimum": 1 },
    "active_attempt_id": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "attempt_count": { "type": "integer", "minimum": 0 },
    "accepted_candidate_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "failure": {
      "anyOf": [
        { "$ref": "#/$defs/failure" },
        { "type": "null" }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": { "enum": ["COMPLETED", "EXHAUSTED", "FAILED"] }
        },
        "required": ["state"]
      },
      "then": {
        "properties": { "terminal": { "const": true } }
      },
      "else": {
        "properties": { "terminal": { "const": false } }
      }
    }
  ],
  "$defs": {
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "controller_state": {
      "enum": [
        "CREATED",
        "CLASSIFYING",
        "CLASSIFIED",
        "POLICY_SELECTED",
        "ATTEMPT_RUNNING",
        "ATTEMPT_COMPLETED",
        "VERIFYING",
        "VERIFIED",
        "REJECTED",
        "ESCALATING",
        "SELECTING",
        "AWAITING_APPROVAL",
        "MATERIALIZING",
        "COMPLETED",
        "EXHAUSTED",
        "FAILED"
      ]
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "details"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}

