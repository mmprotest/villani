{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/cli-invocation.schema.json",
  "title": "Villani CLI Invocation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "executable",
    "executable_identity",
    "arguments",
    "environment",
    "role_workspace_identity",
    "target_repository_writable",
    "cwd",
    "stdin",
    "timeout_seconds",
    "graceful_shutdown_seconds",
    "limits",
    "event_stream_format",
    "utf8_policy",
    "final_output_path",
    "require_final_output",
    "started_at"
  ],
  "properties": {
    "schema_version": { "const": "villani.cli_invocation.v1" },
    "executable": { "type": "string", "minLength": 1 },
    "executable_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "sha256"],
      "properties": {
        "status": { "const": "unresolved" },
        "sha256": { "type": "null" }
      }
    },
    "arguments": { "type": "array", "items": { "type": "string" } },
    "environment": {
      "type": "array",
      "items": { "$ref": "#/$defs/environmentVariable" }
    },
    "role_workspace_identity": { "type": "object" },
    "target_repository_writable": { "type": "boolean" },
    "cwd": { "type": "string", "minLength": 1 },
    "stdin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provided", "size_bytes", "artifact_reference", "sha256"],
      "properties": {
        "provided": { "type": "boolean" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "artifact_reference": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "sha256": {
          "anyOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        }
      }
    },
    "timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
    "graceful_shutdown_seconds": { "type": "number", "minimum": 0 },
    "limits": { "$ref": "#/$defs/outputLimits" },
    "event_stream_format": { "enum": ["none", "jsonl"] },
    "utf8_policy": { "enum": ["replacement", "strict"] },
    "final_output_path": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },
    "require_final_output": { "type": "boolean" },
    "started_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "environmentVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "provenance", "redacted"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "provenance": {
          "enum": ["inherited", "addition", "override", "explicit"]
        },
        "redacted": { "type": "boolean" }
      }
    },
    "outputLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_stdout_bytes",
        "maximum_stderr_bytes",
        "maximum_stdout_chunk_bytes",
        "maximum_stderr_chunk_bytes",
        "maximum_event_line_bytes",
        "maximum_tail_bytes",
        "read_chunk_bytes"
      ],
      "properties": {
        "maximum_stdout_bytes": { "type": "integer", "minimum": 1 },
        "maximum_stderr_bytes": { "type": "integer", "minimum": 1 },
        "maximum_stdout_chunk_bytes": { "type": "integer", "minimum": 1 },
        "maximum_stderr_chunk_bytes": { "type": "integer", "minimum": 1 },
        "maximum_event_line_bytes": { "type": "integer", "minimum": 1 },
        "maximum_tail_bytes": { "type": "integer", "minimum": 1 },
        "read_chunk_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        }
      }
    }
  }
}
