{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/validation-coverage.schema.json",
  "title": "Villani validation coverage v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "attempt_id", "candidate_id", "commands",
    "requirement_ids", "requirements_covered", "requirements_not_covered",
    "generated_at", "migration"
  ],
  "properties": {
    "schema_version": {"const": "villani.validation_coverage.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "validation_id", "command_identity", "argv", "safe_display",
          "execution_role", "working_directory", "status", "exit_status",
          "started_at", "ended_at", "explicitly_named_test_targets",
          "changed_test_files_proven", "changed_test_files_plausibly_included",
          "requirement_ids_covered", "coverage_provenance", "confidence",
          "coverage_unestablished_reasons", "artifact_references"
        ],
        "properties": {
          "validation_id": {"type": "string", "minLength": 1},
          "command_identity": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "safe_display": {"type": "string", "minLength": 1},
          "execution_role": {"type": "string", "minLength": 1},
          "working_directory": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed", "not_run", "unavailable", "infrastructure_error"]},
          "exit_status": {"type": ["integer", "null"]},
          "started_at": {"type": "string", "format": "date-time"},
          "ended_at": {"type": "string", "format": "date-time"},
          "explicitly_named_test_targets": {"type": "array", "items": {"type": "string"}},
          "changed_test_files_proven": {"type": "array", "items": {"type": "string"}},
          "changed_test_files_plausibly_included": {"type": "array", "items": {"type": "string"}},
          "requirement_ids_covered": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "coverage_provenance": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "confidence": {"enum": ["high", "medium", "low", "unknown"]},
          "coverage_unestablished_reasons": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "artifact_references": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "requirement_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "requirements_covered": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "requirements_not_covered": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "generated_at": {"type": "string", "format": "date-time"},
    "migration": {"type": ["object", "null"], "additionalProperties": true}
  }
}
