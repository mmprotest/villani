{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/candidate.schema.json",
  "title": "Villani Durable Candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "run_id", "attempt_id", "task_id", "base_commit", "baseline_sha256", "patch_path", "patch_sha256", "patch_bytes", "changed_files", "untracked_files", "worktree_status", "execution_provider", "execution_environment_fingerprint", "repository_validation_path", "created_at", "materialization_status"],
  "properties": {
    "schema_version": {"const": "villani.candidate.v1"},
    "candidate_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "base_commit": {"type": ["string", "null"]},
    "baseline_sha256": {"type": "string", "minLength": 1},
    "patch_path": {"type": "string", "minLength": 1},
    "patch_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "patch_bytes": {"type": "integer", "minimum": 0},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "untracked_files": {"type": "array", "items": {"type": "string"}},
    "worktree_status": {"type": "object"},
    "execution_provider": {"type": "string", "minLength": 1},
    "execution_environment_fingerprint": {"type": "string", "minLength": 1},
    "repository_validation_path": {"type": "string", "minLength": 1},
    "candidate_patch_quality_path": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "materialization_status": {"enum": ["not_materialized", "succeeded", "failed"]}
  }
}
