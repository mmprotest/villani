{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/candidate-patch-quality.schema.json",
  "title": "Villani Candidate Patch Quality v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "status",
    "tracked_files_changed",
    "relevant_files_changed",
    "untracked_files",
    "ignored_files",
    "villani_owned_files",
    "generated_files",
    "semantic_lines_added",
    "semantic_lines_removed",
    "line_ending_only_lines",
    "whitespace_only_lines",
    "file_mode_only_changes",
    "bulk_rewrite_files",
    "relevant_diff_ratio",
    "reason_codes"
  ],
  "properties": {
    "schema_version": {"const": "villani.candidate_patch_quality.v1"},
    "candidate_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["eligible", "ineligible", "warning"]},
    "tracked_files_changed": {"type": "array", "items": {"type": "string"}},
    "relevant_files_changed": {"type": "array", "items": {"type": "string"}},
    "untracked_files": {"type": "array", "items": {"type": "string"}},
    "ignored_files": {"type": "array", "items": {"type": "string"}},
    "villani_owned_files": {"type": "array", "items": {"type": "string"}},
    "generated_files": {"type": "array", "items": {"type": "string"}},
    "semantic_lines_added": {"type": "integer", "minimum": 0},
    "semantic_lines_removed": {"type": "integer", "minimum": 0},
    "line_ending_only_lines": {"type": "integer", "minimum": 0},
    "whitespace_only_lines": {"type": "integer", "minimum": 0},
    "file_mode_only_changes": {"type": "array", "items": {"type": "string"}},
    "bulk_rewrite_files": {"type": "array", "items": {"type": "string"}},
    "relevant_diff_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "reason_codes": {"type": "array", "items": {"type": "string"}}
  }
}
