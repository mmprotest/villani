{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/run-manifest.schema.json",
  "title": "Villani Run Manifest Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "trace_id",
    "task_id",
    "created_at",
    "updated_at",
    "completed_at",
    "final_state",
    "attempt_ids",
    "selected_attempt_id",
    "total_cost_usd",
    "cost_accounting_status",
    "total_input_tokens",
    "total_output_tokens",
    "token_accounting_status",
    "total_duration_ms",
    "duration_accounting_status",
    "artifact_paths",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "villani.run_manifest.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "created_at": { "$ref": "#/$defs/utc_timestamp" },
    "updated_at": { "$ref": "#/$defs/utc_timestamp" },
    "completed_at": {
      "anyOf": [
        { "$ref": "#/$defs/utc_timestamp" },
        { "type": "null" }
      ]
    },
    "final_state": { "$ref": "#/$defs/controller_state" },
    "attempt_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "selected_attempt_id": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "total_cost_usd": {
      "anyOf": [
        { "type": "number", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "cost_accounting_status": { "$ref": "#/$defs/accounting_status" },
    "total_input_tokens": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "total_output_tokens": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "token_accounting_status": { "$ref": "#/$defs/accounting_status" },
    "total_duration_ms": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "duration_accounting_status": { "$ref": "#/$defs/accounting_status" },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task",
        "classification",
        "state",
        "events",
        "policy_decisions",
        "selection",
        "materialization"
      ],
      "properties": {
        "task": { "type": "string", "minLength": 1 },
        "classification": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1 },
        "events": { "type": "string", "minLength": 1 },
        "policy_decisions": { "type": "string", "minLength": 1 },
        "selection": { "type": "string", "minLength": 1 },
        "materialization": { "type": "string", "minLength": 1 },
        "validation_coverage": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "run_summary": { "type": "string", "minLength": 1 }
        ,"product_run": { "type": "string", "minLength": 1 },
        "agent_systems": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "role_bindings": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "agent_invocations": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "role_invocations": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "route_plans": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "economics_update": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "adaptive_verification": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "human_outcomes": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "supervision_metrics": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "currency": { "type": "string", "pattern": "^[A-Za-z]{3}$" },
    "stage_metrics": { "type": "object", "additionalProperties": { "$ref": "#/$defs/stage_usage" } },
    "total_model_calls": {
      "anyOf": [ { "type": "integer", "minimum": 0 }, { "type": "null" } ]
    },
    "model_call_accounting_status": { "$ref": "#/$defs/accounting_status" },
    "run_wall_clock_duration_ms": {
      "anyOf": [ { "type": "integer", "minimum": 0 }, { "type": "null" } ]
    },
    "run_wall_clock_duration_accounting_status": { "$ref": "#/$defs/accounting_status" },
    "agent_system_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^asys_[0-9a-f]{64}$" },
      "uniqueItems": true
    },
    "execution_profile_id": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "role_bindings": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "agent_invocation_ids": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^ainv_[0-9a-f]{64}$"
      }
    }
  },
  "$defs": {
    "stage_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "backend", "model", "input_tokens", "output_tokens", "total_tokens", "token_accounting_status", "model_calls", "model_call_accounting_status", "cost", "cost_accounting_status", "currency", "duration_ms", "duration_accounting_status", "failure_state"],
      "properties": {
        "stage": { "enum": ["classification", "coding", "verification", "selection", "materialization", "total"] },
        "backend": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "model": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "input_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "output_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "total_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "token_accounting_status": { "$ref": "#/$defs/accounting_status" },
        "model_calls": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "model_call_accounting_status": { "$ref": "#/$defs/accounting_status" },
        "cost": { "anyOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] },
        "cost_accounting_status": { "$ref": "#/$defs/accounting_status" },
        "currency": { "type": "string", "pattern": "^[A-Za-z]{3}$" },
        "duration_ms": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "duration_accounting_status": { "$ref": "#/$defs/accounting_status" },
        "failure_state": { "enum": ["succeeded", "failed", "unknown"] }
      }
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "accounting_status": {
      "enum": ["complete", "partial", "unknown", "not_applicable"]
    },
    "controller_state": {
      "enum": [
        "CREATED",
        "CLASSIFYING",
        "CLASSIFIED",
        "POLICY_SELECTED",
        "ATTEMPT_RUNNING",
        "ATTEMPT_COMPLETED",
        "VERIFYING",
        "VERIFIED",
        "REJECTED",
        "ESCALATING",
        "SELECTING",
        "AWAITING_APPROVAL",
        "MATERIALIZING",
        "COMPLETED",
        "EXHAUSTED",
        "FAILED",
        "CANCELLED"
      ]
    }
  }
}
