{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/run-summary.schema.json",
  "title": "Villani run summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "attempt_id", "checks", "focused_probes",
    "requirements", "accounting", "acceptance", "source_artifacts",
    "generated_at", "migration"
  ],
  "$defs": {
    "evidenceCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "not_run", "unavailable", "accounting_status"],
      "properties": {
        "passed": {"type": ["integer", "null"], "minimum": 0},
        "failed": {"type": ["integer", "null"], "minimum": 0},
        "not_run": {"type": ["integer", "null"], "minimum": 0},
        "unavailable": {"type": ["integer", "null"], "minimum": 0},
        "accounting_status": {"enum": ["complete", "unknown"]}
      },
      "allOf": [
        {
          "if": {"properties": {"accounting_status": {"const": "complete"}}},
          "then": {
            "properties": {
              "passed": {"type": "integer"},
              "failed": {"type": "integer"},
              "not_run": {"type": "integer"},
              "unavailable": {"type": "integer"}
            }
          },
          "else": {
            "properties": {
              "passed": {"type": "null"},
              "failed": {"type": "null"},
              "not_run": {"type": "null"},
              "unavailable": {"type": "null"}
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schema_version": {"const": "villani.run_summary.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": ["string", "null"]},
    "checks": {"$ref": "#/$defs/evidenceCounts"},
    "focused_probes": {"$ref": "#/$defs/evidenceCounts"},
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proved", "not_proved", "accounting_status"],
      "properties": {
        "proved": {"type": ["integer", "null"], "minimum": 0},
        "not_proved": {"type": ["integer", "null"], "minimum": 0},
        "accounting_status": {"enum": ["complete", "unknown"]}
      },
      "allOf": [
        {
          "if": {"properties": {"accounting_status": {"const": "complete"}}},
          "then": {
            "properties": {
              "proved": {"type": "integer"},
              "not_proved": {"type": "integer"}
            }
          },
          "else": {
            "properties": {
              "proved": {"type": "null"},
              "not_proved": {"type": "null"}
            }
          }
        }
      ]
    },
    "accounting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["known", "accounting_status", "total_cost", "currency"],
      "properties": {
        "known": {"type": "boolean"},
        "accounting_status": {"type": "string", "minLength": 1},
        "total_cost": {"type": ["number", "null"], "minimum": 0},
        "currency": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"known": {"const": true}}},
          "then": {
            "properties": {
              "total_cost": {"type": "number"},
              "currency": {"type": "string", "minLength": 1}
            }
          },
          "else": {
            "properties": {
              "total_cost": {"type": "null"},
              "currency": {"type": "null"}
            }
          }
        }
      ]
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason_code", "reason"],
      "properties": {
        "decision": {"type": "boolean"},
        "reason_code": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "source_artifacts": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "generated_at": {"type": "string", "format": "date-time"},
    "migration": {"type": ["object", "null"], "additionalProperties": true}
  }
}
