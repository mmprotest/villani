{
  "$defs": {
    "GateCCheck": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "title": "Actual"
        },
        "check_id": {
          "minLength": 1,
          "title": "Check Id",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "required": {
          "title": "Required"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "insufficient_evidence"
          ],
          "title": "Status",
          "type": "string"
        },
        "system_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "System Id"
        }
      },
      "required": [
        "check_id",
        "status",
        "actual",
        "required",
        "reason"
      ],
      "title": "GateCCheck",
      "type": "object"
    },
    "QualificationAssessment": {
      "additionalProperties": false,
      "properties": {
        "automatic_eligible": {
          "title": "Automatic Eligible",
          "type": "boolean"
        },
        "backoff_evidence": {
          "items": {
            "$ref": "#/$defs/QualificationBackoffEvidence"
          },
          "title": "Backoff Evidence",
          "type": "array"
        },
        "caveat": {
          "minLength": 1,
          "title": "Caveat",
          "type": "string"
        },
        "doctor_action": {
          "minLength": 1,
          "title": "Doctor Action",
          "type": "string"
        },
        "evaluated_at": {
          "format": "date-time",
          "title": "Evaluated At",
          "type": "string"
        },
        "evidence_action": {
          "minLength": 1,
          "title": "Evidence Action",
          "type": "string"
        },
        "manual_override_required": {
          "title": "Manual Override Required",
          "type": "boolean"
        },
        "policy_version": {
          "minLength": 1,
          "title": "Policy Version",
          "type": "string"
        },
        "provisional_fallback_eligible": {
          "title": "Provisional Fallback Eligible",
          "type": "boolean"
        },
        "repository_head": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repository Head"
        },
        "repository_id": {
          "minLength": 1,
          "title": "Repository Id",
          "type": "string"
        },
        "route_name": {
          "minLength": 1,
          "title": "Route Name",
          "type": "string"
        },
        "schema_version": {
          "const": "villani.qualification_assessment.v1",
          "default": "villani.qualification_assessment.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "selected_cohort": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selected Cohort"
        },
        "selected_level": {
          "anyOf": [
            {
              "enum": [
                "exact_repository_task",
                "repository_category",
                "repository_wide",
                "compatible_repository_cohort"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Selected Level"
        },
        "state": {
          "enum": [
            "qualified",
            "provisional",
            "experimental",
            "unsupported"
          ],
          "title": "State",
          "type": "string"
        },
        "statistics": {
          "$ref": "#/$defs/QualificationStatistics"
        },
        "system_id": {
          "pattern": "^asys_[0-9a-f]{64}$",
          "title": "System Id",
          "type": "string"
        },
        "task_profile": {
          "$ref": "#/$defs/QualificationTaskProfile"
        },
        "task_wilson_threshold": {
          "maximum": 1,
          "minimum": 0,
          "title": "Task Wilson Threshold",
          "type": "number"
        },
        "unsupported_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Unsupported Reasons",
          "type": "array"
        }
      },
      "required": [
        "policy_version",
        "system_id",
        "route_name",
        "repository_id",
        "task_profile",
        "state",
        "selected_level",
        "task_wilson_threshold",
        "statistics",
        "backoff_evidence",
        "automatic_eligible",
        "provisional_fallback_eligible",
        "manual_override_required",
        "unsupported_reasons",
        "caveat",
        "doctor_action",
        "evidence_action",
        "evaluated_at"
      ],
      "title": "QualificationAssessment",
      "type": "object"
    },
    "QualificationBackoffEvidence": {
      "additionalProperties": false,
      "properties": {
        "approved_for_qualification": {
          "title": "Approved For Qualification",
          "type": "boolean"
        },
        "cohort": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cohort"
        },
        "eligible_observation_count": {
          "minimum": 0,
          "title": "Eligible Observation Count",
          "type": "integer"
        },
        "level": {
          "enum": [
            "exact_repository_task",
            "repository_category",
            "repository_wide",
            "compatible_repository_cohort"
          ],
          "title": "Level",
          "type": "string"
        },
        "rejection_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Rejection Reasons",
          "type": "array"
        },
        "repository_ids": {
          "items": {
            "type": "string"
          },
          "title": "Repository Ids",
          "type": "array"
        },
        "selected": {
          "title": "Selected",
          "type": "boolean"
        }
      },
      "required": [
        "level",
        "repository_ids",
        "eligible_observation_count",
        "selected",
        "approved_for_qualification"
      ],
      "title": "QualificationBackoffEvidence",
      "type": "object"
    },
    "QualificationDistribution": {
      "additionalProperties": false,
      "properties": {
        "known_count": {
          "minimum": 0,
          "title": "Known Count",
          "type": "integer"
        },
        "maximum": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "median": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median"
        },
        "minimum": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "p90": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "P90"
        },
        "unit": {
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "unknown_count": {
          "minimum": 0,
          "title": "Unknown Count",
          "type": "integer"
        }
      },
      "required": [
        "known_count",
        "unknown_count",
        "unit"
      ],
      "title": "QualificationDistribution",
      "type": "object"
    },
    "QualificationDriftFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "severity": {
          "enum": [
            "warning",
            "severe",
            "unsupported"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "detail"
      ],
      "title": "QualificationDriftFlag",
      "type": "object"
    },
    "QualificationScorecard": {
      "additionalProperties": false,
      "properties": {
        "accepted_as_is": {
          "minimum": 0,
          "title": "Accepted As Is",
          "type": "integer"
        },
        "assessment": {
          "$ref": "#/$defs/QualificationAssessment"
        },
        "failures": {
          "minimum": 0,
          "title": "Failures",
          "type": "integer"
        },
        "false_cases": {
          "minimum": 0,
          "title": "False Cases",
          "type": "integer"
        },
        "harness": {
          "minLength": 1,
          "title": "Harness",
          "type": "string"
        },
        "known_cost": {
          "title": "Known Cost",
          "type": "boolean"
        },
        "known_duration": {
          "title": "Known Duration",
          "type": "boolean"
        },
        "known_review_time": {
          "title": "Known Review Time",
          "type": "boolean"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "proved_acceptable": {
          "minimum": 0,
          "title": "Proved Acceptable",
          "type": "integer"
        },
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "system_name": {
          "minLength": 1,
          "title": "System Name",
          "type": "string"
        }
      },
      "required": [
        "system_name",
        "harness",
        "model",
        "provider",
        "assessment",
        "accepted_as_is",
        "proved_acceptable",
        "false_cases",
        "known_cost",
        "known_duration",
        "known_review_time",
        "failures"
      ],
      "title": "QualificationScorecard",
      "type": "object"
    },
    "QualificationStatistics": {
      "additionalProperties": false,
      "properties": {
        "acceptance_rate": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Acceptance Rate"
        },
        "accepted_as_is_count": {
          "minimum": 0,
          "title": "Accepted As Is Count",
          "type": "integer"
        },
        "accepted_change_cost_by_currency": {
          "additionalProperties": {
            "$ref": "#/$defs/QualificationDistribution"
          },
          "title": "Accepted Change Cost By Currency",
          "type": "object"
        },
        "accepted_change_cost_unknown_count": {
          "minimum": 0,
          "title": "Accepted Change Cost Unknown Count",
          "type": "integer"
        },
        "cost_distribution_by_currency": {
          "additionalProperties": {
            "$ref": "#/$defs/QualificationDistribution"
          },
          "title": "Cost Distribution By Currency",
          "type": "object"
        },
        "cost_unknown_count": {
          "minimum": 0,
          "title": "Cost Unknown Count",
          "type": "integer"
        },
        "drift_flags": {
          "items": {
            "$ref": "#/$defs/QualificationDriftFlag"
          },
          "title": "Drift Flags",
          "type": "array"
        },
        "duration_distribution": {
          "$ref": "#/$defs/QualificationDistribution"
        },
        "exclusions": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Exclusions",
          "type": "object"
        },
        "failures": {
          "minimum": 0,
          "title": "Failures",
          "type": "integer"
        },
        "false_acceptance_count": {
          "minimum": 0,
          "title": "False Acceptance Count",
          "type": "integer"
        },
        "false_case_ids": {
          "items": {
            "type": "string"
          },
          "title": "False Case Ids",
          "type": "array"
        },
        "false_rejection_count": {
          "minimum": 0,
          "title": "False Rejection Count",
          "type": "integer"
        },
        "last_evidence_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Last Evidence At"
        },
        "proved_acceptable_count": {
          "minimum": 0,
          "title": "Proved Acceptable Count",
          "type": "integer"
        },
        "review_minutes_distribution": {
          "$ref": "#/$defs/QualificationDistribution"
        },
        "sample_count": {
          "minimum": 0,
          "title": "Sample Count",
          "type": "integer"
        },
        "software_version_diversity": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Software Version Diversity",
          "type": "object"
        },
        "successes": {
          "minimum": 0,
          "title": "Successes",
          "type": "integer"
        },
        "wilson_lower_bound": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wilson Lower Bound"
        }
      },
      "required": [
        "sample_count",
        "successes",
        "failures",
        "exclusions",
        "proved_acceptable_count",
        "accepted_as_is_count",
        "false_acceptance_count",
        "false_rejection_count",
        "false_case_ids",
        "cost_distribution_by_currency",
        "cost_unknown_count",
        "accepted_change_cost_by_currency",
        "accepted_change_cost_unknown_count",
        "duration_distribution",
        "review_minutes_distribution",
        "last_evidence_at",
        "software_version_diversity",
        "drift_flags"
      ],
      "title": "QualificationStatistics",
      "type": "object"
    },
    "QualificationTaskProfile": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "difficulty": {
          "minLength": 1,
          "title": "Difficulty",
          "type": "string"
        },
        "required_capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Required Capabilities",
          "type": "array"
        },
        "risk": {
          "minLength": 1,
          "title": "Risk",
          "type": "string"
        }
      },
      "required": [
        "category",
        "difficulty",
        "risk"
      ],
      "title": "QualificationTaskProfile",
      "type": "object"
    }
  },
  "$id": "https://villani.dev/schemas/v1/gate-c.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "$ref": "#/$defs/GateCCheck"
      },
      "minItems": 1,
      "title": "Checks",
      "type": "array"
    },
    "evidence_snapshot_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Evidence Snapshot Digest"
    },
    "gate": {
      "const": "C",
      "default": "C",
      "title": "Gate",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "policy_version": {
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "repository_head": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Repository Head"
    },
    "repository_id": {
      "minLength": 1,
      "title": "Repository Id",
      "type": "string"
    },
    "schema_version": {
      "const": "villani.gate_c.v1",
      "default": "villani.gate_c.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scorecards": {
      "items": {
        "$ref": "#/$defs/QualificationScorecard"
      },
      "title": "Scorecards",
      "type": "array"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL",
        "INSUFFICIENT_EVIDENCE"
      ],
      "title": "Status",
      "type": "string"
    },
    "task_profile": {
      "$ref": "#/$defs/QualificationTaskProfile"
    },
    "unmatched_sample_warning": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Unmatched Sample Warning"
    }
  },
  "required": [
    "generated_at",
    "repository_id",
    "task_profile",
    "policy_version",
    "status",
    "checks",
    "scorecards"
  ],
  "title": "GateCReport",
  "type": "object"
}
