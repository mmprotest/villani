{
  "$defs": {
    "RouteConstraints": {
      "additionalProperties": false,
      "properties": {
        "allow_experimental_forced": {
          "default": false,
          "title": "Allow Experimental Forced",
          "type": "boolean"
        },
        "allowed_permission_profiles": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Permission Profiles",
          "type": "array"
        },
        "allowed_providers": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Providers",
          "type": "array"
        },
        "excluded_systems": {
          "items": {
            "type": "string"
          },
          "title": "Excluded Systems",
          "type": "array"
        },
        "forced_system": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Forced System"
        },
        "local_only": {
          "default": false,
          "title": "Local Only",
          "type": "boolean"
        },
        "maximum_known_cost_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Known Cost Usd"
        },
        "prefer_local": {
          "default": false,
          "title": "Prefer Local",
          "type": "boolean"
        },
        "preferred_provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Provider"
        },
        "strongest_only": {
          "default": false,
          "title": "Strongest Only",
          "type": "boolean"
        }
      },
      "title": "RouteConstraints",
      "type": "object"
    }
  },
  "$id": "https://villani.dev/schemas/v1/route-policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allow_provisional_fallback": {
      "default": true,
      "title": "Allow Provisional Fallback",
      "type": "boolean"
    },
    "conservative_cost_statistic": {
      "default": "p90",
      "enum": [
        "p90",
        "median"
      ],
      "title": "Conservative Cost Statistic",
      "type": "string"
    },
    "conservative_duration_statistic": {
      "default": "p90",
      "enum": [
        "p90",
        "median"
      ],
      "title": "Conservative Duration Statistic",
      "type": "string"
    },
    "constraints": {
      "$ref": "#/$defs/RouteConstraints"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Za-z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "human_review_cost_per_minute": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Human Review Cost Per Minute"
    },
    "latency_penalty_per_second": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Penalty Per Second"
    },
    "objective_version": {
      "const": "total_accepted_change_v1",
      "default": "total_accepted_change_v1",
      "title": "Objective Version",
      "type": "string"
    },
    "policy_version": {
      "default": "accepted_change_economics_v1",
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "require_complete_objective_for_comparison": {
      "default": true,
      "title": "Require Complete Objective For Comparison",
      "type": "boolean"
    },
    "schema_version": {
      "const": "villani.route_policy.v1",
      "default": "villani.route_policy.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "strategy": {
      "default": "accepted_change_optimizer",
      "enum": [
        "accepted_change_optimizer",
        "strongest_only",
        "cheapest_qualified",
        "forced"
      ],
      "title": "Strategy",
      "type": "string"
    }
  },
  "title": "RoutePolicy",
  "type": "object"
}
