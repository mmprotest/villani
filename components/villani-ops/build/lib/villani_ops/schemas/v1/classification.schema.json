{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villani.dev/schemas/v1/classification.schema.json",
  "title": "Villani Classification Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "classification_id",
    "run_id",
    "task_id",
    "classified_at",
    "difficulty",
    "risk",
    "category",
    "required_capabilities",
    "estimated_attempts_needed",
    "needs_tests",
    "confidence",
    "reasoning_summary",
    "signals",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "villani.classification.v1" },
    "classification_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "classified_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "difficulty": { "enum": ["easy", "medium", "hard"] },
    "risk": { "enum": ["low", "medium", "high"] },
    "category": { "type": "string", "minLength": 1 },
    "required_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "estimated_attempts_needed": { "type": "integer", "minimum": 1 },
    "needs_tests": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reasoning_summary": { "type": "string" },
    "signals": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "llm_usage": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage_usage" }
    }
  },
  "$defs": {
    "stage_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "backend", "model", "input_tokens", "output_tokens", "total_tokens", "token_accounting_status", "model_calls", "model_call_accounting_status", "cost", "cost_accounting_status", "currency", "duration_ms", "duration_accounting_status", "failure_state"],
      "properties": {
        "stage": { "enum": ["classification", "coding", "verification", "selection", "materialization", "total"] },
        "backend": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "model": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
        "input_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "output_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "total_tokens": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "token_accounting_status": { "enum": ["complete", "partial", "unknown", "not_applicable"] },
        "model_calls": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "model_call_accounting_status": { "enum": ["complete", "partial", "unknown", "not_applicable"] },
        "cost": { "anyOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] },
        "cost_accounting_status": { "enum": ["complete", "partial", "unknown", "not_applicable"] },
        "currency": { "type": "string", "pattern": "^[A-Za-z]{3}$" },
        "duration_ms": { "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "duration_accounting_status": { "enum": ["complete", "partial", "unknown", "not_applicable"] },
        "failure_state": { "enum": ["succeeded", "failed", "unknown"] }
      }
    }
  }
}
