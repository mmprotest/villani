{
  "name": "villani-flight-recorder",
  "version": "0.1.0",
  "description": "Local-first static replay generator for AI coding agent sessions and git history.",
  "type": "module",
  "bin": {
    "villani-flight-recorder": "dist/cli.js",
    "vfr": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.10",
    "jsdom": "^24.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
